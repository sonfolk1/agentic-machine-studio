{
  "name": "agentic-studio",
  "version": "0.1.0",
  "description": "Agentic Studio — a standalone desktop tool for autonomous OpenRouter agentic loops with local filesystem and shell access.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env ELECTRON_DEV=1 electron .\"",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build": "npm run build:renderer && npm run build:electron",
    "package": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:dir": "npm run build && electron-builder --mac --dir --config electron-builder.yml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/ws": "^8.18.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.agenticstudio.app",
    "productName": "Agentic Studio"
  }
}
