{
  "manifest_version": 3,
  "name": "Agentic Studio Bridge",
  "version": "0.1.1",
  "description": "Lets Agentic Studio drive Chrome — navigate tabs, click, type, screenshot.",
  "permissions": ["tabs", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "ws://127.0.0.1/*",
    "ws://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agentic Studio Bridge"
  }
}
